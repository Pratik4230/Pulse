# App — for local dev, set both to http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Better Auth — must match the URL you open in the browser
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Resend (password reset + email verification)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Pulse <onboarding@yourdomain.com>

# Google OAuth (Better Auth login + Corsair Gmail/Calendar later)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (Better Auth login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Corsair (self-hosted)
CORSAIR_KEK=
# Gmail push notifications (Pub/Sub topic, e.g. projects/my-project/topics/gmail-push)
GOOGLE_PUBSUB_TOPIC=

# AI
OPENAI_API_KEY=

# Sarvam (voice input — Saaras v3 STT)
SARVAM_API_KEY=

DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_SECRET=
DODO_PAYMENTS_ENVIRONMENT=test_mode
# Pro subscription product ID from Dodo dashboard (pdt_...)
DODO_PRO_PRODUCT_ID=
# Pro display price in USD (minor units) for marketing / billing UI — 8000 = $80.00/mo
PRO_PRICE_USD=8000
